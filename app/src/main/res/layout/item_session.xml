<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="4dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:id="@+id/textSessionDuration"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Duration: 00:00:00"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@android:color/black" />

        <TextView
            android:id="@+id/textSessionProductivity"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Productivity: 0"
            android:layout_marginTop="6dp"
            android:textSize="14sp"
            android:textColor="@android:color/darker_gray" />

        <TextView
            android:id="@+id/textSessionFatigue"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Fatigue: 0"
            android:layout_marginTop="4dp"
            android:textSize="14sp"
            android:textColor="@android:color/darker_gray" />

        <TextView
            android:id="@+id/textSessionNotes"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Notes: ..."
            android:layout_marginTop="6dp"
            android:textSize="14sp"
            android:textColor="@android:color/black"
            android:visibility="gone" />

        <TextView
            android:id="@+id/textSessionDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="2026-04-28"
            android:layout_marginTop="6dp"
            android:textSize="12sp"
            android:textColor="@android:color/darker_gray" />

    </LinearLayout>

</androidx.cardview.widget.CardView>