<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:id="@+id/textTimeValue"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="00:00:00"
        android:textSize="20sp"/>

    <TextView
        android:id="@+id/textProductivityValue"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Productivity: 1 / 5"/>

    <SeekBar
        android:id="@+id/seekBarProductivity"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:max="4"/>

    <TextView
        android:id="@+id/textFatigueValue"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Fatigue: 1 / 5"/>

    <SeekBar
        android:id="@+id/seekBarFatigue"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:max="4"/>

    <EditText
        android:id="@+id/editNotes"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Notes"/>

    <Button
        android:id="@+id/buttonSaveResult"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Save Result"/>

</LinearLayout>